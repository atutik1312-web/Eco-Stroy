server {
    server_name eckostroy.ru www.eckostroy.ru;
    root /var/www/eco-stroy;
    index index.html;

    # ��������� ��� ������� ��������
    location /media/ {
        alias /var/www/eco-media/;
        expires 30d; # �����: �������� �������� ���������� �������� �� 30 ���� ��� ��������
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/eckostroy.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/eckostroy.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}server {
    if ($host = www.eckostroy.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = eckostroy.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name eckostroy.ru www.eckostroy.ru;
    return 404; # managed by Certbot




}